---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RichText from '../components/RichText.tsx';
import { fetchPrivacyPolicy } from '../data/privacyPolicy';

const { title, content, avisoPdfUrl } = await fetchPrivacyPolicy();
---

<Layout
  title={`${title} | Construred`}
  description="Aviso de Privacidad de Construred conforme a la Ley Federal de Protección de Datos Personales en Posesión de los Particulares."
>
  <Header />

  <main class="pt-28 pb-20 bg-white">
    <article class="container mx-auto px-4 lg:px-8 max-w-3xl">
      <h1 class="font-display text-4xl md:text-5xl tracking-wider text-secondary-dark mb-10">
        {title}
      </h1>
      <RichText client:load data={content} avisoPdfUrl={avisoPdfUrl} />
    </article>
  </main>

  <Footer />
</Layout>
