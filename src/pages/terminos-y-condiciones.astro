---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RichText from '../components/RichText.tsx';
import { fetchTermsAndConditions } from '../data/termsAndConditions';
import { fetchAvisoPdfUrl } from '../data/privacyPolicy';

const [{ title, content }, avisoPdfUrl] = await Promise.all([
  fetchTermsAndConditions(),
  fetchAvisoPdfUrl(),
]);
---

<Layout
  title={`${title} | Construred`}
  description="Términos y Condiciones de uso del sitio y los servicios de Construred."
>
  <Header />

  <main class="pt-28 pb-20 bg-white">
    <article class="container mx-auto px-4 lg:px-8 max-w-3xl">
      <h1 class="font-display text-4xl md:text-5xl tracking-wider text-secondary-dark mb-10">
        {title}
      </h1>
      <RichText client:load data={content} avisoPdfUrl={avisoPdfUrl} />
    </article>
  </main>

  <Footer />
</Layout>
