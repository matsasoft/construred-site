---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HeroSlider from '../components/HeroSlider.tsx';
import AboutSection from '../components/AboutSection.astro';
import GoogleMap from '../components/GoogleMap.tsx';
import ContactForm from '../components/ContactForm.tsx';
import Footer from '../components/Footer.astro';
import { fetchStores } from '../data/stores';
import { fetchHeroSlides } from '../data/heroSlides';

const [stores, heroSlides] = await Promise.all([
	fetchStores(),
	fetchHeroSlides(),
]);
---

<Layout>
	<Header />

	<main>
		<!-- Hero Section with Slider -->
		{heroSlides.length > 0 && <HeroSlider slides={heroSlides} client:load />}

		<!-- About Section -->
		<AboutSection />

		<!-- Locations Map Section -->
		<GoogleMap client:visible stores={stores} />

		<!-- Contact Form Section -->
		<ContactForm client:visible cmsApiUrl={import.meta.env.PUBLIC_CMS_API_URL} />
	</main>

	<Footer />

</Layout>
