---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const {
	title = "Construred | Ferreterías y Materiales de Construcción",
	description = "En Construred encuentras todo el material eléctrico, de construcción y plomería para tus proyectos. La mejor atención personalizada y los mejores precios.",
	image = "/CONSTRURED logo-01.png"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://construred.mx');

const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const gaEnabled = import.meta.env.PROD && typeof gaId === 'string' && gaId.startsWith('G-');
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/CONSTRURED_logo-500x500px.png" />
		<link rel="apple-touch-icon" href="/CONSTRURED_logo-500x500px.png" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="keywords" content="ferretería, materiales de construcción, plomería, material eléctrico, construred, remodelación, herramientas, cotización" />
		<meta name="author" content="Construred" />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:locale" content="es_MX" />
		<meta property="og:site_name" content="Construred" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={image} />

		<!-- Schema.org LocalBusiness -->
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "LocalBusiness",
			"name": "Construred",
			"image": "/CONSTRURED logo-01.png",
			"description": "Ferreterías y cadena de distribución de materiales para la construcción",
			"@id": "https://construred.mx",
			"url": "https://construred.mx",
			"telephone": "+52-555-123-4567",
			"priceRange": "$$",
			"address": {
				"@type": "PostalAddress",
				"addressLocality": "Ciudad de México",
				"addressCountry": "MX"
			},
			"openingHoursSpecification": {
				"@type": "OpeningHoursSpecification",
				"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
				"opens": "08:00",
				"closes": "19:00"
			},
			"sameAs": []
		}
		</script>

		<!-- Preconnect to external resources -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		{gaEnabled && (
			<>
				<script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
				<script is:inline define:vars={{ gaId }}>
					window.dataLayer = window.dataLayer || [];
					function gtag(){ dataLayer.push(arguments); }
					window.gtag = gtag;
					gtag('js', new Date());
					gtag('config', gaId, { anonymize_ip: true });

					document.addEventListener('click', (e) => {
						const target = e.target;
						if (!(target instanceof Element)) return;
						const anchor = target.closest('a[href^="#"]');
						if (!anchor) return;
						const href = anchor.getAttribute('href') || '';
						const section = href.slice(1);
						if (!section) return;
						gtag('event', 'anchor_click', { section });
					});
				</script>
			</>
		)}
	</head>
	<body class="min-h-screen flex flex-col">
		<slot />
	</body>
</html>
