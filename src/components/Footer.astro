---
const currentYear = new Date().getFullYear();

const quickLinks = [
    { label: 'Inicio', href: '#inicio' },
    { label: 'Nosotros', href: '#nosotros' },
    { label: 'Ubicaciones', href: '#ubicaciones' },
    { label: 'Contacto', href: '#contacto' }
];

const services = [
    'Material Eléctrico',
    'Material de Plomería',
    'Material de Construcción',
    'Herramientas',
    'Asesoría Técnica'
];

const socialLinks = [
    {
        name: 'Facebook',
        href: '#',
        icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`
    },
    {
        name: 'Instagram',
        href: '#',
        icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>`
    },
    {
        name: 'YouTube',
        href: '#',
        icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`
    }
];
---

<footer class="bg-secondary-dark text-white relative overflow-hidden">
    {/* Top Decorative Border */}
    <div class="h-2 bg-gradient-to-r from-primary via-accent to-primary"></div>

    {/* Industrial Pattern Overlay */}
    <div class="absolute inset-0 opacity-5">
        <div class="absolute top-0 right-0 w-96 h-96 bg-primary rounded-full -translate-y-1/2 translate-x-1/2"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-accent rounded-full translate-y-1/2 -translate-x-1/2"></div>
    </div>

    <div class="container mx-auto px-4 lg:px-8 py-16 relative">
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12">
            {/* Logo & Description */}
            <div class="lg:col-span-1">
                <a href="#inicio" class="inline-block mb-6">
                    <img
                        src="/CONSTRURED logo-01.png"
                        alt="Construred Logo"
                        class="h-16 w-auto"
                    />
                </a>
                <p class="text-neutral-400 mb-6 leading-relaxed">
                    Tu ferretería de confianza. Todo el material eléctrico, de construcción y plomería para tus proyectos.
                </p>
                {/* Social Links */}
                <div class="flex gap-4">
                    {socialLinks.map((social) => (
                        <a
                            href={social.href}
                            class="w-10 h-10 bg-white/10 flex items-center justify-center text-white hover:bg-primary hover:text-secondary-dark transition-all duration-300"
                            aria-label={social.name}
                        >
                            <Fragment set:html={social.icon} />
                        </a>
                    ))}
                </div>
            </div>

            {/* Quick Links */}
            <div>
                <h3 class="text-xl font-display tracking-wider mb-6 text-primary">Enlaces</h3>
                <ul class="space-y-3">
                    {quickLinks.map((link) => (
                        <li>
                            <a
                                href={link.href}
                                class="text-neutral-400 hover:text-primary transition-colors duration-300 flex items-center gap-2 group"
                            >
                                <span class="w-2 h-2 bg-primary/50 group-hover:bg-primary transition-colors duration-300"></span>
                                {link.label}
                            </a>
                        </li>
                    ))}
                </ul>
            </div>

            {/* Services */}
            <div>
                <h3 class="text-xl font-display tracking-wider mb-6 text-primary">Servicios</h3>
                <ul class="space-y-3">
                    {services.map((service) => (
                        <li class="text-neutral-400 flex items-center gap-2">
                            <span class="w-2 h-2 bg-accent/50"></span>
                            {service}
                        </li>
                    ))}
                </ul>
            </div>

            {/* Contact Info */}
            <div>
                <h3 class="text-xl font-display tracking-wider mb-6 text-primary">Contacto</h3>
                <div class="space-y-4">
                    <div class="flex items-start gap-3">
                        <div class="w-8 h-8 bg-primary/20 flex items-center justify-center shrink-0 mt-1">
                            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                        </div>
                        <div>
                            <p class="text-neutral-400 text-sm">Ciudad de México y área metropolitana</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 bg-primary/20 flex items-center justify-center shrink-0">
                            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                            </svg>
                        </div>
                        <p class="text-neutral-400">55 1234 5678</p>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 bg-primary/20 flex items-center justify-center shrink-0">
                            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                            </svg>
                        </div>
                        <p class="text-neutral-400">contacto@construred.mx</p>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 bg-primary/20 flex items-center justify-center shrink-0">
                            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <p class="text-neutral-400">Lun - Sáb: 8:00 - 19:00</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {/* Bottom Bar */}
    <div class="border-t border-white/10">
        <div class="container mx-auto px-4 lg:px-8 py-6">
            <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                <p class="text-neutral-500 text-sm text-center md:text-left">
                    &copy; {currentYear} Construred. Todos los derechos reservados.
                </p>
                <div class="flex items-center gap-6 text-sm text-neutral-500">
                    <a href="#" class="hover:text-primary transition-colors duration-300">Aviso de Privacidad</a>
                    <a href="#" class="hover:text-primary transition-colors duration-300">Términos y Condiciones</a>
                </div>
            </div>
        </div>
    </div>

    {/* Meny Mascot */}
    <div class="absolute bottom-4 right-4 w-24 h-24 opacity-30 hidden lg:block">
        <img
            src="/Meny-07.png"
            alt="Meny"
            class="w-full h-full object-contain"
        />
    </div>
</footer>
