---
import MobileMenu from "./MobileMenu.tsx";
import Button from "./Button.astro";

const currentPath = Astro.url.pathname;

const navItems = [
    { label: "Inicio", href: "/#inicio" },
    { label: "Nosotros", href: "/#nosotros" },
    { label: "Ubicaciones", href: "/sucursales" },
    { label: "Contacto", href: "/#contacto" },
];

function isActive(href: string, currentPath: string): boolean {
    if (href === "/sucursales") return currentPath === "/sucursales" || currentPath === "/sucursales/";
    if (href.startsWith("/#")) return currentPath === "/" || currentPath === "";
    return false;
}
---

<header
    id="header"
    class="fixed top-0 left-0 right-0 z-50 bg-white transition-shadow duration-300"
>
    <div class="container mx-auto px-4 lg:px-8">
        <div class="flex items-center justify-between h-20">
            <!-- Logo -->
            <a
                href="/"
                class="relative z-50 flex items-center gap-3 group"
            >
                <img
                    src="/CONSTRURED logo-01.png"
                    alt="Construred Logo"
                    class="h-30 w-auto transition-transform duration-300 group-hover:scale-105"
                />
            </a>

            <!-- Desktop Navigation -->
            <nav class="hidden lg:flex items-center gap-8">
                {
                    navItems.map((item) => {
                        const active = isActive(item.href, currentPath);
                        return (
                            <a
                                href={item.href}
                                class:list={[
                                    "nav-link font-display text-lg tracking-wider transition-colors duration-300 relative group",
                                    active ? "text-primary" : "text-secondary hover:text-primary",
                                ]}
                            >
                                {item.label}
                                <span
                                    class:list={[
                                        "absolute -bottom-1 left-0 h-0.5 bg-primary transition-all duration-300",
                                        active ? "w-full" : "w-0 group-hover:w-full",
                                    ]}
                                />
                            </a>
                        );
                    })
                }
            </nav>

            <!-- CTA Button (Desktop) -->
            <Button
                variant="primary"
                size="sm"
                href="/sucursales"
                class="hidden lg:inline-flex px-6 py-2.5"
            >
                Buscar Tienda
            </Button>

            <!-- Mobile Menu -->
            <MobileMenu client:load items={navItems} currentPath={currentPath} />
        </div>
    </div>

    <!-- Decorative bottom border -->
    <div
        class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary to-transparent opacity-0 transition-opacity duration-300"
        id="header-border"
    >
    </div>
</header>

<script>
    const header = document.getElementById("header");
    const headerBorder = document.getElementById("header-border");
    let lastScrollY = 0;

    function updateHeader() {
        const scrollY = window.scrollY;
        const isScrolled = scrollY > 50;

        if (isScrolled) {
            header?.classList.add("shadow-lg");
            headerBorder?.classList.replace("opacity-0", "opacity-100");
        } else {
            header?.classList.remove("shadow-lg");
            headerBorder?.classList.replace("opacity-100", "opacity-0");
        }

        // Hide on scroll down, show on scroll up
        if (scrollY > lastScrollY && scrollY > 200) {
            header?.classList.add("-translate-y-full");
        } else {
            header?.classList.remove("-translate-y-full");
        }

        lastScrollY = scrollY;
    }

    window.addEventListener("scroll", updateHeader, { passive: true });
    updateHeader();
</script>
