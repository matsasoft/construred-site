# Construred Site - Environment Variables

# Google Maps API Key
# Obtén tu API Key en: https://console.cloud.google.com/google/maps-apis
# Asegúrate de habilitar las siguientes APIs:
# - Maps JavaScript API
# - Places API (opcional)
PUBLIC_GOOGLE_MAPS_API_KEY=tu_api_key_aqui

# Payload CMS API URL (servidor, solo build-time)
CMS_API_URL=http://localhost:3000

# Payload CMS API URL (público, accesible desde el navegador)
PUBLIC_CMS_API_URL=http://localhost:3000

# Google Analytics 4 Measurement ID (formato G-XXXXXXXXXX)
# Crea la propiedad en: https://analytics.google.com → Admin → Crear propiedad → Data stream Web
# Si está vacío o no es PROD, GA4 no se carga.
PUBLIC_GA_MEASUREMENT_ID=
